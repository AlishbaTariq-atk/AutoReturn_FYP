            "alert": 7,
            "severe": 8,
            "crash": 8,
            "failure": 7,
            "stopped": 6,
            "breach": 9,
            "escalate": 7,
            "escalation": 7,
            "sos": 10,
            "help": 5,
            "stuck": 5,
            "dying": 6,
            "desperate": 7,
            "panic": 7
        },

        "time_pressure": {
            "_description": "Words that imply time sensitivity or a deadline.",
            "today": 7,
            "tonight": 7,
            "tomorrow": 5,
            "deadline": 8,
            "due": 6,
            "overdue": 9,
            "eod": 8,
            "eob": 7,
            "end of day": 8,
            "end of business": 7,
            "by noon": 8,
